---
import CopyBlock from "./CopyBlock.astro";
import TerminalConversation from "./TerminalConversation.astro";
import { installCmd } from "../data/install";
---

<section class="hero">
  <div class="container hero-stack">
    <div class="hero-intro">
      <p class="hero-eyebrow">Tasks + Calendar · TUI + Agent-Native</p>
      <h1>
        Your calendar speaks shell<br />
        your agent gets it
      </h1>
      <p class="hero-lead">
        Local-first tasks and Google Calendar sync. Capture in a backlog, schedule
        when it matters, and work from the TUI, CLI, or your agent.
      </p>
      <CopyBlock id="install-cmd" text={installCmd} class="hero-copy-block" />
      <p class="hero-meta">
        macOS via Homebrew · also installable from source ·
        <a href="https://github.com/alexapvl/mytime">GitHub</a>
      </p>
      <div class="hero-actions">
        <a class="btn" href="#setup">Get Started</a>
        <a class="btn btn-ghost" href="https://github.com/alexapvl/mytime">View Source</a>
      </div>
    </div>
    <div class="hero-demo">
      <TerminalConversation />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100svh - var(--header-height));
    padding-block: clamp(2.5rem, 5vh, 3.5rem) calc(var(--section-peek) + 3.5rem);
  }

  .hero-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(3.5rem, 7vh, 4.5rem);
  }

  .hero-intro {
    width: 100%;
  }

  .hero-eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--cyan-dim);
  }

  .hero h1 {
    margin: 0 0 1.25rem;
    max-width: 14em;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .hero-lead {
    margin: 0 0 2rem;
    max-width: 40rem;
    color: var(--text-muted);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  .hero-intro :global(.copy-wrap) {
    width: 100%;
    max-width: none;
  }

  .hero-intro :global(.copy-block) {
    width: 100%;
  }

  .hero-intro :global(.copy-block code) {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .hero-meta {
    margin: 1rem 0 1.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-demo {
    width: 100%;
    max-width: 56rem;
    margin-inline: auto;
  }
</style>
