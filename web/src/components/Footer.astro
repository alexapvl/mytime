---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div>
      <span class="footer-brand">mytime</span>
      <p class="footer-tag">Local tasks and calendar for people who live in the terminal.</p>
    </div>
    <div class="footer-right">
      <nav class="footer-links" aria-label="Footer">
        <a href="https://github.com/alexapvl/mytime">GitHub</a>
        <a href="https://github.com/alexapvl/mytime/releases">Releases</a>
        <a href="https://github.com/alexapvl/mytime#readme">Docs</a>
      </nav>
      <p class="footer-meta">
        © {currentYear} mytime. Made by <a href="https://apvl.dev">apvl.dev</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: 2.5rem 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    margin-left: auto;
  }

  .footer-brand {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .footer-tag {
    margin: 0.375rem 0 0;
    max-width: 22rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .footer-meta {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-align: right;
  }
</style>
