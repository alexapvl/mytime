{
  "name": "mytime",
  "version": "0.1.5",
  "description": "Unified tasks + calendar CLI with Google and Apple Calendar sync",
  "type": "module",
  "packageManager": "pnpm@9.5.0",
  "bin": {
    "mytime": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && scripts/build-eventkit-helper.sh",
    "build:native": "scripts/build-eventkit-helper.sh",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "pack:macos": "scripts/build-macos-pack.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@googleapis/calendar": "^15.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "better-sqlite3": "^12.11.1",
    "chrono-node": "^2.7.7",
    "google-auth-library": "^10.9.0",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "luxon": "^3.5.0",
    "react": "^18.3.1",
    "string-width": "^8.2.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
